name: Edge Equation Posting Scheduler

on:
  workflow_dispatch:
    inputs:
      mode:
        description: "Select the mode to run"
        required: true
        type: choice
        options:
          - fact_domestic
          - edges_morning
          - spotlight
          - edges_evening
          - results

  schedule:
    - cron: "30 12 * * *"   # 7:30 AM CT → fact_domestic
    - cron: "30 15 * * *"   # 10:30 AM CT → edges_morning
    - cron: "30 20 * * *"   # 3:30 PM CT → spotlight
    - cron: "0 23 * * *"    # 6:00 PM CT → edges_evening
    - cron: "30 2 * * *"    # 9:30 PM CT → results

jobs:
  run_mode:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Run selected mode
        run: python main.py --mode "${{ github.event.inputs.mode }}"
